# ===== 角色 → Provider 路由 =====
PLANNER_PROVIDER=claude
CODER_PROVIDER=deepseek
REVIEWER_PROVIDER=gpt
FRONTEND_PROVIDER=gemini

# ===== 前端优化开关 =====
# true  → coder 写完后再让 Gemini(agy) 做一轮前端优化
# false → 不调 Gemini，前端代码完全由 DeepSeek 按 plan §4 写
FRONTEND_ENABLED=true

# ===== 每个 Provider 的调用模式（cli = 走本机 CLI 订阅；sdk = 走 API key）=====
CLAUDE_MODE=cli
GPT_MODE=cli
GEMINI_MODE=cli
DEEPSEEK_MODE=sdk

# ===== CLI 路径（install.sh 自动探测填入；可手改）=====
CLAUDE_CLI_PATH=
GPT_CLI_PATH=
GEMINI_CLI_PATH=
DEEPSEEK_CLI_PATH=

# ===== API Keys（仅 *_MODE=sdk 时使用，可留空）=====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ===== 模型版本 =====
CLAUDE_MODEL=claude-opus-4-7
GPT_MODEL=gpt-4.1
DEEPSEEK_MODEL=deepseek-coder
GEMINI_MODEL=gemini-2.5-pro

# ===== 可选：自定义 API endpoint =====
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
DEEPSEEK_BASE_URL=
GEMINI_BASE_URL=

# ===== 行为开关 =====
AI_DEBUG=0
AI_TIMEOUT=120
AI_MAX_RETRY=3
